{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "leo-kb-doc-v1",
  "title": "LEO KB Document",
  "description": "Schema for all documents in the LEO Knowledge Base",
  "type": "object",
  "required": ["id", "type", "lifecycle", "scope", "tags", "created", "created_by", "updated", "updated_by", "content"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Unique identifier, kebab-case. Must match filename (minus .json)"
    },
    "type": {
      "type": "string",
      "enum": ["constraint", "skill", "identity", "decision", "fact", "feedback", "reference", "session-log", "pattern", "learning"],
      "description": "Document type — determines which content sub-schema applies"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["permanent", "learning", "state"],
      "description": "permanent = rarely changes, learning = slow decay, state = fast decay"
    },
    "scope": {
      "type": "string",
      "enum": ["core", "project"],
      "description": "core = universal (from LEO core), project = specific to this project"
    },
    "boot": {
      "type": "boolean",
      "description": "If true, this doc is loaded at boot time"
    },
    "summary": {
      "type": "string",
      "description": "Concise one-line description used by the adapter to render in the runtime context file"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Tags are the synapses — lowercase kebab-case, free-form"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime of creation"
    },
    "created_by": {
      "type": "string",
      "description": "Which agent or actor created this doc (e.g., leo, engineer-manager, owner)"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime of last modification"
    },
    "updated_by": {
      "type": "string",
      "description": "Which agent or actor last modified this doc"
    },
    "session_id": {
      "type": "string",
      "description": "Links this document to the session that produced it"
    },
    "confidence": {
      "type": "string",
      "enum": ["EXTRACTED", "INFERRED", "AMBIGUOUS"],
      "description": "Epistemic confidence: EXTRACTED = explicit assertion, INFERRED = deduction, AMBIGUOUS = uncertain. Default: INFERRED."
    },
    "promotion_state": {
      "type": "string",
      "enum": ["draft", "curated", "validated", "deprecated"],
      "description": "Lifecycle / process state. Default: draft."
    },
    "classification": {
      "type": "string",
      "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL"],
      "description": "Access classification for ABAC. Default: INTERNAL."
    },
    "compartments": {
      "type": "object",
      "description": "Customer-defined need-to-know dimensions. Default: {} (no restrictions).",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "description": "Capture provenance — runtime, session, trigger, and raw exhaust reference.",
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "string",
          "description": "Runtime that captured this memory (e.g., claude-code, cursor, cline, codex)"
        },
        "session_id": {
          "type": "string",
          "description": "Session identifier linking to SessionEvent telemetry"
        },
        "trigger_event": {
          "type": "string",
          "description": "Event that triggered capture (e.g., session.end, compact.triggered, clear.triggered)"
        },
        "commit_sha": {
          "type": "string",
          "description": "Git commit SHA at time of capture (set by git integration, not the runtime)"
        },
        "raw_exhaust_ref": {
          "type": "string",
          "description": "Pointer to the raw pre-processed capture payload (file path or blob hash)"
        }
      }
    },
    "landmark": {
      "type": "boolean",
      "description": "True if this memory is a navigation landmark. Default: false. Populated by the landmarks computation job (#65)."
    },
    "centrality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Graph centrality score 0.0–1.0. Default: null. Populated by the landmarks computation job (#65)."
    },
    "content": {
      "type": "object",
      "description": "Shape depends on type — see oneOf"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "constraint" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["constraint", "why", "how_to_apply", "responsibility"],
            "additionalProperties": false,
            "properties": {
              "constraint": {
                "type": "string",
                "description": "The core constraint statement (1-3 sentences)"
              },
              "why": {
                "type": "string",
                "description": "Why this constraint exists, what problem it prevents"
              },
              "how_to_apply": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1,
                "description": "Concrete instructions or sub-rules"
              },
              "examples": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["situation", "wrong", "right"],
                  "additionalProperties": false,
                  "properties": {
                    "situation": { "type": "string" },
                    "wrong": { "type": "string" },
                    "right": { "type": "string" }
                  }
                }
              },
              "anti_patterns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "responsibility": {
                "type": "string",
                "description": "Who enforces this constraint"
              },
              "mechanisms": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "description", "when"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "description": { "type": "string" },
                    "when": {
                      "type": "string",
                      "enum": ["preventive", "reactive", "structural", "reflective"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "skill" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["description", "triggers", "invoked_by", "steps", "do_not"],
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string",
                "description": "What this skill does"
              },
              "triggers": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Natural language patterns that invoke this skill"
              },
              "invoked_by": {
                "type": "string",
                "description": "Who can invoke (e.g., leo, any-manager, owner)"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "instruction", "wait_for_approval"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "instruction": { "type": "string" },
                    "wait_for_approval": { "type": "boolean" }
                  }
                },
                "minItems": 1
              },
              "do_not": {
                "type": "array",
                "items": { "type": "string" }
              },
              "output_format": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "identity" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["what"],
            "additionalProperties": false,
            "properties": {
              "what": {
                "type": "string",
                "description": "What this project/product is (1-3 sentences)"
              },
              "stack": {
                "type": "array",
                "items": { "type": "string" }
              },
              "philosophy": {
                "type": "string"
              },
              "constraints": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "decision" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["decision", "context", "why", "alternatives_considered", "impact", "reversible"],
            "additionalProperties": false,
            "properties": {
              "decision": {
                "type": "string",
                "description": "What was decided"
              },
              "context": {
                "type": "string",
                "description": "What led to this decision"
              },
              "why": {
                "type": "string",
                "description": "Why this decision was made"
              },
              "alternatives_considered": {
                "type": "array",
                "items": { "type": "string" }
              },
              "impact": {
                "type": "array",
                "items": { "type": "string" }
              },
              "reversible": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "fact" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["fact", "why", "source"],
            "additionalProperties": false,
            "properties": {
              "fact": {
                "type": "string",
                "description": "The factual statement"
              },
              "why": {
                "type": "string",
                "description": "Why this fact matters"
              },
              "source": {
                "type": "string"
              },
              "expires": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "feedback" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["feedback", "why", "how_to_apply"],
            "additionalProperties": false,
            "properties": {
              "feedback": {
                "type": "string",
                "description": "The correction or guidance"
              },
              "why": {
                "type": "string",
                "description": "Why the owner gave this feedback"
              },
              "how_to_apply": {
                "type": "string",
                "description": "When and where this guidance kicks in"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "reference" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["description", "purpose"],
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string",
                "description": "What this resource is"
              },
              "url": {
                "type": "string"
              },
              "purpose": {
                "type": "string",
                "description": "Why this reference matters"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "session-log" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["session_id", "timestamp", "repo", "tasks"],
            "additionalProperties": false,
            "properties": {
              "session_id": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "repo": { "type": "string" },
              "wrap_up_revisions": { "type": "integer", "minimum": 0 },
              "tasks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["task_id", "timestamp", "summary"],
                  "additionalProperties": false,
                  "properties": {
                    "task_id": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "summary": { "type": "string" },
                    "tags": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "pattern" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["pattern"],
            "additionalProperties": true,
            "properties": {
              "pattern": {
                "type": "string",
                "description": "The structural or behavioral pattern observed"
              },
              "why": {
                "type": "string",
                "description": "Why this pattern matters"
              },
              "source": {
                "type": "string",
                "description": "Where this pattern was extracted from"
              },
              "name": {
                "type": "string",
                "description": "Symbol or construct name (set by AST extractor)"
              },
              "language": {
                "type": "string",
                "description": "Programming language (set by AST extractor)"
              },
              "kind": {
                "type": "string",
                "description": "Symbol kind: function, type, method, class, etc."
              },
              "doc": {
                "type": "string",
                "description": "Doc comment extracted from source"
              },
              "symbol": {
                "type": "string",
                "description": "Symbol name (set by non-Go AST extractor)"
              },
              "summary": {
                "type": "string",
                "description": "Human-readable summary"
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "learning" } } },
      "then": {
        "properties": {
          "content": {
            "type": "object",
            "required": ["learning"],
            "additionalProperties": true,
            "properties": {
              "learning": {
                "type": "string",
                "description": "What was learned or observed"
              },
              "why": {
                "type": "string",
                "description": "Why this learning matters"
              },
              "how_to_apply": {
                "type": "string",
                "description": "When and where to apply this learning"
              },
              "source": {
                "type": "string",
                "description": "Where this learning came from"
              }
            }
          }
        }
      }
    }
  ]
}
