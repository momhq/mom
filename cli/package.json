{
  "name": "leo-core",
  "version": "0.2.0",
  "description": "LEO — Living Ecosystem Orchestrator. CLI for setup, project onboarding, KB migration, and AI agent management.",
  "type": "module",
  "bin": {
    "leo": "./dist/index.js",
    "copilot-core": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "prepare": "npm run build && node scripts/save-core-path.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
