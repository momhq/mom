{
  "name": "copilot-core",
  "version": "0.1.0",
  "description": "CLI for copilot-core — setup, onboard projects, and manage your AI agent system",
  "type": "module",
  "bin": {
    "copilot-core": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
